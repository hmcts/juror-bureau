{% extends "layouts/default.njk" %}

{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "includes/csrf.njk" import csrfProtection %}

{% set currentApp = "Electoral register management" %}

{% block page_title %}{{ serviceName }} - Electoral register management{% endblock %}
{% block page_identifier %}Electoral register management{% endblock %}

{% block content %}

  {% include "includes/errors.njk" %} 

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">{{ localAuthorityInfo.localAuthorityName }}</span>
      <h1 class="govuk-heading-xl govuk-!-margin-bottom-6">Mark authority as active</h1>

      {% set insetText %}
        <p class="govuk-body govuk-!-font-weight-bold">Reason for deactivation</p>
        <p class="govuk-body">{{ localAuthorityInfo.inactiveInfo.inactiveReason }}</p>
      {% endset %}
      {{ govukInsetText({
        html: insetText
      }) }}

      <p class="govuk-body">Activating the account will require the local authority to upload electoral register data.</p>

      <form action="{{ postUrl }}" method="post" id="activateLaForm">
        <div class="govuk-button-group">
          {{ govukButton({
            text: "Mark as active",
            type: "submit"
          }) }}

          <a class="govuk-link govuk-link--no-visited-state" href="{{ cancelUrl }}">Cancel</a>
        </div>

        {{ csrfProtection(csrftoken) }}
      </form>

    </div>
  </div>

{% endblock %}
