{% from "./uploaded-doughnut-macro.njk" import uploadedDoughnut %}

<div id="uploaded-doughnut" class="govuk-grid-row" aria-label="uploaded LA doughnut chart">
  <div class="govuk-grid-column-full">
    <div class="mod-dashboard__chart" aria-label="Uploaded LA doughnut chart">
      <div class="doughnut-values">
        <div class="doughnut-values__chart">
          {{ uploadedDoughnut({
            id: "uploadedLADoughnut",
            values: {
              uploaded: uploaded,
              notUploaded: notUploaded
            },
            nonce: nonce
          }) }}
        </div>
      </div>
    </div>
  </div>
</div>