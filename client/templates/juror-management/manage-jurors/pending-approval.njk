{% from "govuk/components/table/macro.njk" import govukTable %}

{% if jurors | length > 0 %}

  {% set jurorRows = [] %}

  {% for juror in jurors %}
    {% set notes = "" %}
    {% if juror.notes %}
      {% if 'SJO Comments' in juror.notes %}
        {% set notes = juror.notes.split('SJO Comments')[0] + "<br /><br /><strong>SJO Comments</strong><br />" + juror.notes.split('SJO Comments')[1] 
          if juror.notes.split('SJO Comments')[0] !== '' 
          else "<strong>SJO Comments</strong><br />" + juror.notes.split('SJO Comments')[1] %}
      {% else %}
        {% set notes = juror.notes %}
      {% endif %}
    {% endif %}

    {% if juror.pendingJurorStatus.description === "Queued" %}
      {% if pendingLink %}
        {% set status = "<a class='govuk-link' href=" + pendingLink + juror.jurorNumber + ">Pending approval</a>" %}
      {% else %}
        {% set status = "Pending approval" %}
      {% endif %}
    {% else %}
      {% if juror.pendingJurorStatus.description === "Authorised" %}
        {% set status = "Approved" %}
      {% else %}
        {% set status = juror.pendingJurorStatus.description | capitalizeFully %}
      {% endif%}
    {% endif %}

    {% set jurorRows = (jurorRows.push(
      [
        {
          text: juror.jurorNumber
        },
        {
          text: juror.firstName | capitalizeFully
        },
        {
          text: juror.lastName | capitalizeFully
        },
        {
          html: notes
        },
        {
          text: juror.postcode
        },
        {
          html: status,
          classes: 'not-pending-table-cell' if juror.pendingJurorStatus.description != "Queued" else ''
        }
      ]
    ), jurorRows) %}

  {% endfor %}

  {{ govukTable({
    caption: "Pending approval",
    captionClasses: "govuk-visually-hidden",
    head: [
      {
        text: "Juror number",
        attributes: {
          "aria-label": "Juror number"
        }
      },
      {
        text: "First name",
        attributes: {
          "aria-label": "First name"
        }
      },
      {
        text: "Last name",
        attributes: {
          "aria-label": "Last name"
        }
      },
      {
        text: "Notes",
        attributes: {
          "aria-label": "Notes"
        }
      },
      {
        text: "Postcode",
        attributes: {
          "aria-label": "Postcode"
        }
      },
      {
        text: "Status",
        attributes: {
          "aria-label": "Status"
        }
      }
    ],
    rows: jurorRows
  }) }}

{% else %}

  <p class="govuk-body">There are no pending jurors to approve.</p>

{% endif %}
