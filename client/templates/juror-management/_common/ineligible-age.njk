{% extends "../../layouts/default-no-nav.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block page_title %}{{ serviceName }} - Inelegible age{% endblock %}
{% block page_identifier %}Inelegible age{% endblock %}

{% set currentApp = currentApp %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">

      <form method="post" action="{{ postUrl }}" id="ineligibleAgeConfirm" >

        <h1 class="govuk-heading-xl">Check the juror's age</h1>

        <p class="govuk-body govuk-!-margin-bottom-5">You entered the new service start date as {{ newServiceStartDate }}.</p>

        <p class="govuk-body govuk-!-margin-bottom-5">The juror's date of birth is {{ dob }}.</p>
            
        <p class="govuk-body">This means they will be {{ yearsOld }} years old on their new service start date and are not eligible for jury service.</p>

        <h2 class="govuk-heading-m  govuk-!-margin-bottom-6">Do you want to disqualify this juror?</h2>

        <div class="govuk-button-group">
          {{ govukButton({
              text: "Yes - disqualify juror",
              type: "submit",
              attributes: {
              id: "disqualifyButton"
            }
          }) }}

          <a class="govuk-link" href="{{ cancelUrl }}">No - change service start date</a>
        </div>
        <input type="hidden" id="disqualifyReason" name="disqualifyReason" value="A">
        <input type="hidden" id="csrfToken" name="_csrf" value="{{ csrftoken }}">
      </form>

    </div>
  </div>

{% endblock %}