{% from "./sms-doughnut-macro.njk" import smsDoughnut %}

<div id="sms-doughnut" class="govuk-grid-row" aria-label="outgoing sms messages doughnut chart">
  <div class="govuk-grid-column-full">
    <div class="mod-dashboard__chart" aria-label="Outgoing SMS messages doughnut chart">
      <div class="doughnut-values">
        <div class="doughnut-values__chart">
          {{ smsDoughnut({
            id: "outgoingSmsDoughnut",
            values: section.chart.data,
            nonce: nonce
          }) }}
        </div>
      </div>
    </div>
  </div>
</div>