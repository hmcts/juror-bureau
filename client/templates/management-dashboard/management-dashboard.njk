{% extends "layouts/default.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% set currentApp = "System administration" %}
{% set nav = "managementDashboard" %}

{% set currentPage = "homepage" %}

{% block page_title %}Juror homepage{% endblock %}
{% block page_identifier %}Homepage{% endblock %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% for table in tables %}

        <div class="govuk-grid-row">
          <div class="govuk-grid-column-{% if table.exportReportLink %}two-thirds{% else %}full{% endif %}">
            <h2 class="govuk-heading-m {% if table.subCaption %} govuk-!-margin-bottom-0 {% endif %}">{{ table.caption }}</h2>
            {% if table.subCaption %}
              <span class="govuk-caption-m govuk-!-margin-bottom-3">{{ table.subCaption }}</span>
            {% endif %}
          </div>
          {% if table.exportReportLink %}
            <div class="govuk-grid-column-one-third moj-button-group--inline mod-flex mod-justify-end">
              {{ govukButton({
                text: "Export report",
                href: table.exportReportLink,
                classes: "govuk-button--secondary"
              }) }}
            </div>
          {% endif %}
        </div>

        <div class="govuk-grid-row govuk-!-margin-bottom-9">
          <div class="govuk-grid-column-full">
            {% if table.chart %}
              {% include "management-dashboard/_partials/" + table.chart.template + ".njk" %}
            {% endif %}
            {% if table.rows | length %}
              {{ govukTable({
                head: table.head,
                rows: table.rows
              }) }}
            {% else %}
              {% if not table.staticLink %}
                <p class="govuk-body">No records to show</p>
              {% endif %}
            {% endif %}
            {% if table.staticLink %}
              <a class="govuk-body govuk-link" href="{{ table.staticLink.link }}">{{ table.staticLink.text }}</a>
            {% endif %}
            {% if table.reportLink %}
              <a class="govuk-body govuk-link" href="{{ table.reportLink }}">Show all</a>
            {% endif %}
          </div>
        </div>
        
      {% endfor %}
    </div>
  </div>

{% endblock %}