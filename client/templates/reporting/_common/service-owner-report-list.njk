{% set todayDate = "" | makeDate | dateFilter(null, "yyyy-MM-DD")%}

{% if isSuperUser %}
  <h2 class="govuk-heading-m">Service owner reports</h2>
  <ul class="govuk-list">
    <li><a class="govuk-link" href="{{ url('reports.expense-payments.filter.dates.get') }}">Expense payment by type</a></li>
    <li><a class="govuk-link" href="{{ url('reports.outgoing-sms-messages.filter.dates.get') }}">Outgoing SMS messages</a></li>
    <li><a class="govuk-link" href="{{ url('reports.weekend-attendance.report.get', { filter: 'all' }) }}">Courts recording weekend attendance this month</a></li>
    <li><a class="govuk-link" href="{{ url('reports.expense-limit-adjustments.report.get', { filter: 'all' }) }}">Manual adjustments to expense limits</a></li>
    <li><a class="govuk-link" href="{{ url('reports.courts-incomplete-service.report.get', { filter: todayDate }) }}">Courts with incomplete service</a></li>
  </ul>
{% endif %}
