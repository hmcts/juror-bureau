{% extends "layouts/default-no-nav.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "includes/csrf.njk" import csrfProtection %}

{% block page_title %}{{ serviceName }} - Reports - {{ reportName }} - Select months{% endblock %}
{% block page_identifier %}Reports - {{ reportName }} - Select months{% endblock %}

{% set currentApp = "System administration" if isSystemAdministrator and isSuperUser else "Reports" %}

{% block content %}
  {% include "includes/errors.njk" %}

  {% set selectMonthFromError = undefined %}
  {% if errors.items["selectMonthFrom"] %}
    {% set selectMonthFromError = {text: errors.items["selectMonthFrom"][0].details} %}
  {% endif %}

  {% set selectMonthToError = undefined %}
  {% if errors.items["selectMonthTo"] %}
    {% set selectMonthToError = {text: errors.items["selectMonthTo"][0].details} %}
  {% endif %}

  <form action="{{ processUrl }}" method="post" id="sittingDaysMonthRangeForm">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">{{ reportName }}</h1>
      </div>
    </div>
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        {{ govukSelect({
          id: "selectMonthFrom",
          name: "selectMonthFrom",
          label: {
            text: "Month from",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Select the first reporting month to include."
          },
          errorMessage: selectMonthFromError,
          items: monthsFrom
        }) }}

        {{ govukSelect({
          id: "selectMonthTo",
          name: "selectMonthTo",
          label: {
            text: "Month to",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Select the last reporting month to include."
          },
          errorMessage: selectMonthToError,
          items: monthsTo
        }) }}

        {{ csrfProtection(csrftoken) }}
        <div class="govuk-button-group">
          {{ govukButton({
            text: "Continue",
            type: "submit"
          }) }}
          <a href="{{ cancelUrl }}" class="govuk-link" id="cancelAnchor">Cancel</a>
        </div>
      </div>
    </div>
  </form>
{% endblock %}
