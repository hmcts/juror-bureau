{% extends "layouts/default.njk" %}

{% from "moj/components/alert/macro.njk" import mojAlert %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{%- from "moj/components/button-menu/macro.njk" import mojButtonMenu -%}

{% block page_title %}{{ serviceName }} - Trial management - Trials{% endblock %}
{% block page_identifier %}Trial management - Trials{% endblock %}

{% set currentApp = "Trials" %}
{% set trialDetails = [
  {
    key: {
      text: "Defendants" if trial.trialType === "Criminal" else "Respondents"
    },
    value: {
      text: trial.defendants
    }
  },
  {
    key: {
      text: "Trial type"
    },
    value: {
      text: trial.trialType | capitalizeFully
    }
  },
  {
    key: {
      text: "Trial start date"
    },
    value: {
      text: trial.trialStartDate | makeDate | dateFilter("YYYY,MM,DD", "dddd D MMMM YYYY")
    }
  },
  {
    key: {
      text: "Judge"
    },
    value: {
      text: trial.judge.description
    }
  },
  {
    key: {
      text: "Courtroom"
    },
    value: {
      text: trial.courtroomsDto.description | capitalizeFully
    }
  },
  {
    key: {
      text: "Protected?"
    },
    value: {
      text: "Yes" if trial.protectedTrial else "No"
    }
  }
]%}

{% set endDateRow =
  {
    key: {
      text: "Trial end date"
    },
    value: {
      text: trial.trialEndDate | makeDate | dateFilter("YYYY,MM,DD", "dddd D MMMM YYYY")
    }
  }
%}

{% set standardPrintMenuItems = [
  {
    text: "Ballot cards",
    href: url("reports.ballot-cards.report.print", { ballotType: "trial", filter: trial.trialNumber }),
    classes: "govuk-button--secondary",
    attributes: {
      target: "_blank"
    }
  },
  {
    text: "Panel list (summary)",
    href: url("reports.panel-summary.trial-juror-select.get", { "filter": trial.trialNumber }),
    classes: "govuk-button--secondary"
  },
  {
    text: "Panel list (detailed)",
    href: url("reports.panel-detail.trial-juror-select.get", { "filter": trial.trialNumber }),
    classes: "govuk-button--secondary"
  },
  {
    text: "Panel member status report",
    href: url("reports.panel-members-status.trial-juror-select.get", { "filter": trial.trialNumber }),
    classes: "govuk-button--secondary"
  },
  {
    text: "Trial attendance report",
    href: url("reports.trial-attendance.trial-juror-select.get", { "filter": trial.trialNumber }),
    classes: "govuk-button--secondary"
  }
]%}


{% if not trial.isActive %}
  {% set trialDetails = (trialDetails.splice(3, 0, endDateRow), trialDetails)%}
{% endif %}

{% block content %}

  {% include "includes/errors.njk" %}

  {% if successBanner %}
    {{ mojAlert({
      variant: "success",
      html: successBanner,
      iconFallbackText: "Success"
    }) }}
  {% endif %}

  {% if errorBanner %}
    {{ mojAlert({
      variant: "warning",
      html: errorBanner,
      iconFallbackText: "Warning"
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half trial-detail__header">
      <span class="trial-detail__header-label">Trial</span>
      <div class="trial-detail__header-number">
        <h1 class="govuk-heading-l govuk-!-margin-bottom-0">{{ trial.trialNumber }}</h1>
          {{ govukTag({
            text: "Active" if trial.isActive else "Inactive",
            classes: "govuk-tag--blue" if trial.isActive else "govuk-tag--grey"
          }) }}
      </div>
    </div>
    <div class="govuk-grid-column-one-half">
      <div class="govuk-button-group moj-button-group--inline mod-flex mod-justify-end">
        {% if trial.isActive %}
          {% if canReinstateJury %}
            {{ govukButton({
              text: "Reinstate jury",
              classes: "govuk-button--secondary",
              href: url('trial-management.trials.reinstate-jury.get', {trialNumber: trial.trialNumber, locationCode: locationCode})
            }) }}
          {% endif %}
          {% if addPanelStatus %}
            {{ govukButton({
              text: "Add panel members",
              classes: "govuk-button--secondary",
              href: url('trial-management.add-panel-members.get', {trialNumber: trial.trialNumber, locationCode: locationCode})
            }) }}
          {% endif %}
          {% if trial.panelledJurors | length > 0 %}
            {{ govukButton({
              text: "Empanel jury",
              classes: "govuk-button--secondary",
              href: url('trial-management.empanel.get', {trialNumber: trial.trialNumber, locationCode: locationCode})
            }) if canEmpanel }}

            {{ govukButton({
              text: "End trial",
              classes: "govuk-button--secondary",
              href: url('trial-management.trials.end-trial.get', {trialNumber: trial.trialNumber, locationCode: locationCode})
            }) }}
          {% else %}
            {% if addPanelStatus === false %}
              {{ govukButton({
                text: "Generate panel",
                classes: "govuk-button--secondary",
                href: url('trial-management.generate-panel.get', {trialNumber: trial.trialNumber, locationCode: locationCode})
              }) }}
            {% endif %}
            {{ govukButton({
              text: "Edit trial",
              classes: "govuk-button--secondary",
              href: url("trial-management.edit-trial.get", { trialNumber: trial.trialNumber, locationCode: locationCode })
            }) }}
            {{ govukButton({
              text: "End trial",
              classes: "govuk-button--secondary",
              href: url('trial-management.trials.end-trial.get', {trialNumber: trial.trialNumber, locationCode: locationCode})
            }) }}
          {% endif %}
          
        {% endif %}
        {{ mojButtonMenu({
          button: {
            text: "Print",
            classes: "govuk-button--secondary"
          },
          alignMenu: "right",
          items: [
            {
              text: "Jury list",
              href: url("reports.jury-list.trial-juror-select.get", {'filter': trial.trialNumber}),
              classes: "govuk-button--secondary"
            }
          ].concat(standardPrintMenuItems) if trial.isJuryEmpanelled else standardPrintMenuItems,
          attributes: {
            id: 'printButtonMenu'
          }
        }) }}
      </div>
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half govuk-body">
      {{ govukSummaryList({
        rows: trialDetails
      }) }}
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% if trial.panelledJurors | length > 0 %}
        {% include "./_partials/trial-panel.njk" %}
      {% endif %}
    </div>
  </div>

{% endblock %}
